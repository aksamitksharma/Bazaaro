# Bazaaro Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/bazaaro

# JWT
JWT_SECRET=bazaaro_super_secret_key_change_in_production
JWT_EXPIRE=30d

# Cloudinary (mock - not needed for dev)
CLOUDINARY_CLOUD_NAME=demo
CLOUDINARY_API_KEY=demo
CLOUDINARY_API_SECRET=demo

# Razorpay (mock - not needed for dev)
RAZORPAY_KEY_ID=rzp_test_demo
RAZORPAY_KEY_SECRET=demo_secret

# Google Maps (using OpenStreetMap instead for dev)
GOOGLE_MAPS_API_KEY=

# Client URL
CLIENT_URL=http://localhost:5173
